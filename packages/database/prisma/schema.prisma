generator client {
  provider        = "prisma-client-js"
  output          = "../generated"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================
// ENUMS
// =====================================================================

enum InsuranceType {
  PRIVATHAFTPFLICHT
  HAUSRAT
  KFZ
  BERUFSUNFAEHIGKEIT
  ZAHNZUSATZ
  PFLEGE
  UNFALL
  RECHTSSCHUTZ
  AUSLANDS_KRANKEN
}

enum PaymentInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RelationshipStatus {
  SINGLE
  IN_A_RELATIONSHIP
  MARRIED
}

enum VehicleType {
  NONE
  SCOOTER
  CAR
  MOTORCYCLE
  PUBLIC_TRANSPORT
}

enum HousingType {
  SHARED_ROOM
  APARTMENT
  HOUSE
}

enum HousingOwnershipType {
  RENTING
  MORTGAGE
  OWNER
}

enum JobType {
  STUDENT
  APPRENTICE
  EMPLOYEE
  SEARCHING
}

enum GoalType {
  CHEAPEST
  BEST_VALUE
  COMPREHENSIVE
}

enum CoverageStatus {
  MISSING
  WEAK
  ADEQUATE
  GOOD
  EXCELLENT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  JOB_STARTED
  JOB_PROGRESS
  JOB_COMPLETED
  JOB_FAILED
  SYSTEM
}

// =====================================================================
// AUTH & USER TABLES (Merged & Backward Compatible)
// =====================================================================

model User {
  id            String    @id @default(cuid())
  name          String?   // Kept optional to maintain compatibility with old schema
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  language      Language  @default(GERMAN)

  // Auth relations
  sessions      Session[]
  accounts      Account[]

  // App relations (First Schema)
  insurances    Insurance[]
  proposals     Proposal[]
  questionnaire Questionnaire?

  // App relations (Old Schema)
  jobs                Job[]
  notifications       Notification[]
  coverageAssessments CoverageAssessment[]

  @@map("users")
}

enum Language {
  GERMAN
  ENGLISH
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @db.Text @map("access_token") // @db.Text kept from first schema
  refreshToken          String?   @db.Text @map("refresh_token")
  idToken               String?   @db.Text @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, providerId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verifications")
}

// =====================================================================
// APP SPECIFIC TABLES (From First Schema)
// =====================================================================

model Insurance {
  id            String          @id @default(cuid())
  type          InsuranceType
  company       String          @default("Unsere Partner-Versicherung AG")
  rate          Decimal         @db.Decimal(10, 2)
  interval      PaymentInterval
  number        String
  coverageScore Int?            // 0-100, quality score set by AI worker

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]

  @@map("insurance")
}

model Document {
  id          String    @id @default(cuid())
  title       String
  url         String
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  insuranceId String
  insurance   Insurance @relation(fields: [insuranceId], references: [id], onDelete: Cascade)

  @@map("document")
}

model Proposal {
  id              String          @id @default(cuid())
  type            InsuranceType
  company         String
  rate            Decimal         @db.Decimal(10, 2)
  interval        PaymentInterval @default(MONTHLY)
  templateId      String
  isAiGenerated   Boolean         @default(true)
  priority        Int?            // 1 = highest priority, 5 = lowest
  reason          String?         // Summary / why this is a good fit
  keyBenefits     String[]        // Key benefits of this insurance
  actionSuggestion String?        // Suggested next step for the user

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("proposal")
}

model Questionnaire {
  id                   String                @id @default(cuid())
  dateOfBirth          DateTime              @db.Date
  
  // Adresse (optional – collected in a later flow)
  streetName           String?
  streetNumber         String?
  zipcode              String?
  city                 String?

  // Beruf & Finanzen
  jobType              JobType
  jobExpiryDate        DateTime?             @db.Date
  salary               Decimal?              @db.Decimal(10, 2)

  // Lebenssituation
  relationshipStatus   RelationshipStatus
  childrenCount        Int                   @default(0)

  // Besitztümer & Wohnen
  vehicleTypes         VehicleType[]
  housingType          HousingType?
  housingOwnershipType HousingOwnershipType?
  goal                 GoalType?

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  userId               String                @unique
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("questionnaire")
}

// ============================================================================
// COVERAGE ASSESSMENTS (AI-generated per insurance type, filled by worker)
// ============================================================================

model CoverageAssessment {
  id        String         @id @default(cuid())
  type      InsuranceType
  status    CoverageStatus @default(MISSING)
  score     Int            @default(0) // 0-100
  priority  Int            @default(3) // 1=critical, 5=optional
  notes     String?

  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  userId    String         @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("coverage_assessments")
}

// ============================================================================
// JOBS & NOTIFICATIONS (From Old Schema)
// ============================================================================

model Job {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  priority    Int       @default(0)
  progress    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("jobs")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([read])
  @@map("notifications")
}

model SyncCursor {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  entity    String   // e.g., "notifications", "jobs"
  cursor    DateTime // last synced timestamp
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, entity])
  @@map("sync_cursors")
}