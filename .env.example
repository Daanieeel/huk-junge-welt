# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/huk_db?schema=public"

# MinIO (S3-compatible document storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="huk-documents"

# Redis
REDIS_URL="redis://localhost:6379"

# App Ports
REST_PORT=3001
WEBSOCKET_PORT=3002
WEB_PORT=3000

# BullMQ
BULLMQ_REDIS_URL="redis://localhost:6379"

# Pub/Sub
PUBSUB_REDIS_URL="redis://localhost:6379"

# Better Auth
BETTER_AUTH_SECRET="local-dev-secret-change-me-32-chars"
BETTER_AUTH_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Frontend
NEXT_PUBLIC_REST_URL="http://localhost:3001"
NEXT_PUBLIC_WEBSOCKET_URL="ws://localhost:3002"

# RAG-Webhook (optional for local startup)
RAG_WEBHOOK_URL=""
RAG_WEBHOOK_AUTH=""
