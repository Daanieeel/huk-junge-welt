{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream-with-experimental-timestamps",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "BULLMQ_REDIS_URL",
    "PUBSUB_REDIS_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "WEB_URL",
    "REST_PORT",
    "WEBSOCKET_PORT",
    "WEB_PORT",
    "RAG_WEBHOOK_URL",
    "RAG_WEBHOOK_AUTH"
  ],
  "globalPassThroughEnv": [
    "NEXT_PUBLIC_REST_URL",
    "NEXT_PUBLIC_WEBSOCKET_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^db:generate"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
